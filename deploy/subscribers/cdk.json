{
  "app": "python3 app.py",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "requirements*.txt",
      "site/**",
      "tests/**",
      "**/__pycache__",
      "**/*.pyc"
    ]
  },
  "context": {
